# tokyo-emit-cli golden fixtures are standalone crates (their own [workspace]
# table) so `cargo build` inside them, done routinely when verifying the
# emitter, produces its own build artifacts — only the generated source
# should be checked in, not these.
crates/codegen/emit-cli/tests/golden/*/target/
crates/codegen/emit-cli/tests/golden/*/Cargo.lock
